# ============================================================
# auth-service - DEV environment template
# ------------------------------------------------------------
# Copy this file to .env (in this same folder) and load it
# from your IDE Run Configuration (e.g. EnvFile plugin in IntelliJ).
# Defaults in YAML are PROD-safe; this file overrides for DEV.
# ============================================================

# --- Spring Cloud Config Server ---
# DEV: config-server runs locally from IDE
CONFIG_IMPORT=optional:configserver:http://localhost:8888
CONFIG_FAIL_FAST=false

# --- Server ---
SERVER_PORT=8081

# --- Eureka discovery ---
# DEV: discovery-service runs locally from IDE
EUREKA_URL=http://localhost:8761/eureka

# --- Datasource (MySQL) ---
# DEV: docker-compose.infra.yml exposes MySQL on host port 3307 -> container 3306
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/auth_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JPA (DEV verbose; YAML defaults are PROD-safe) ---
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# --- RabbitMQ ---
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=
SPRING_RABBITMQ_PASSWORD=

# --- JWT (RSA keypair) ---
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Paste each PEM as a single line using literal \n for line breaks.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# --- Password reset ---
PASSWORD_RESET_EXPIRATION_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=3
PASSWORD_RESET_BLOCK_MINUTES=15

# --- Service clients (OAuth2 client_credentials) ---
# DataInit seeds these into the DB. If left blank, the warning
# "Service client X no configurado" will appear and the other
# microservices will NOT be able to authenticate service-to-service.
HOTEL_SERVICE_CLIENT_ID=
HOTEL_SERVICE_CLIENT_SECRET=
HOTEL_SERVICE_CLIENT_SCOPE=service:hotel
RESERVA_SERVICE_CLIENT_ID=
RESERVA_SERVICE_CLIENT_SECRET=
RESERVA_SERVICE_CLIENT_SCOPE=service:reserva
NOTIFICACION_SERVICE_CLIENT_ID=
NOTIFICACION_SERVICE_CLIENT_SECRET=
NOTIFICACION_SERVICE_CLIENT_SCOPE=service:notificacion

# --- CORS (DEV: Angular dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200
